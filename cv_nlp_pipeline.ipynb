      "source": [
        "from ultralytics import YOLO\n",
        "from transformers import pipeline\n",
        "\n",
        "cv = YOLO('yolov8n.pt')\n",
        "result = cv('dog1.jpg')\n",
        "result[0].show()\n",
        "\n",
        "nlp = pipeline('sentiment-analysis')\n",
        "text = \"The bread is very fresh and tasty\"\n",
        "output = nlp(text)\n",
        "\n",
        "print(output[0]['label'])"
      ]
    }
  ]
}